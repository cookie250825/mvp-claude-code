model:
  provider: deepseek
  name: deepseek-chat
  baseUrl: https://api.deepseek.com/v1
  apiKey: ${DEEPSEEK_API_KEY}
  temperature: 0.7
  maxTokens: 4096

tools:
  builtin: [file, bash, search]
  mcp:
    enabled: false
    servers:
      - name: filesystem
        command: npx
        args: ["-y", "@modelcontextprotocol/server-filesystem", "."]

context:
  compactThreshold: 50000              # token 阈值，触发 auto compact
  maxRounds: 0                         # 最大轮次：0=不限（靠 token 预算），>0=轮次上限
  maxContextTokens: 128000             # 上下文窗口大小（DeepSeek/Claude 默认 128K）
  contextDangerRatio: 0.9              # 水位危险比例：用量达 90% 触发压缩，95% 熔断

memory:
  dir: ~/.agent/memory

security:
  workspace: ""  # 留空=当前工作目录；填写绝对路径=限制文件操作范围
